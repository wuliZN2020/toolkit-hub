@import url('https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@300;400;500&display=swap');

/* 海洋莫兰迪配色 - 清澈透亮 */
:root {
  --ocean-bg: linear-gradient(180deg, #E8F4F8 0%, #D4E9F2 50%, #C5E0EB 100%);
  --ocean-light: #F5FAFB;
  --ocean-card: rgba(255, 255, 255, 0.75);
  --ocean-text: #3A5F6F;
  --ocean-text-light: #6B8B9C;
  --ocean-blue: #7BA5B8;
  --ocean-blue-deep: #5B8BA0;
  --ocean-aqua: #88C5D8;
  --ocean-foam: #A8D8E6;
  --ocean-border: rgba(123, 165, 184, 0.2);
  --ocean-shadow: rgba(123, 165, 184, 0.12);
  --wave-shimmer: rgba(136, 197, 216, 0.3);
  --ocean-hover-bg: rgba(168, 216, 230, 0.08);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.book-quote-container {
  width: 100%;
  min-height: 100vh;
  background: var(--ocean-bg);
  padding: 60px 24px 80px;
  font-family: 'Noto Serif SC', 'Ma Shan Zheng', serif;
  position: relative;
  overflow: hidden;
}

.book-quote-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255, 255, 255, 0.03) 2px,
      rgba(255, 255, 255, 0.03) 4px
    );
  z-index: 0;
  animation: water-shimmer 20s ease-in-out infinite;
}

@keyframes water-shimmer {
  0%, 100% {
    opacity: 0.4;
  }
  50% {
    opacity: 0.6;
  }
}

.content-wrapper {
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
}

/* 隐藏背景装饰 */
.bg-decoration {
  display: none;
}

/* 页头 */
.hero-section {
  text-align: center;
  margin-bottom: 60px;
}

.hero-badge {
  display: inline-block;
  padding: 6px 16px;
  background: transparent;
  border: 1px solid var(--morandi-border);
  border-radius: 20px;
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 1px;
  color: var(--morandi-text-light);
  margin-bottom: 20px;
}

.hero-badge::before,
.hero-badge::after {
  display: none;
}

.hero-title {
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 300;
  color: var(--morandi-text);
  line-height: 1.3;
  margin: 0 0 16px 0;
  letter-spacing: -0.02em;
}

.hero-title .highlight {
  font-weight: 500;
  color: var(--morandi-accent);
}

.hero-title .highlight::after {
  display: none;
}

.hero-subtitle {
  font-size: clamp(14px, 2vw, 16px);
  color: var(--morandi-text-light);
  max-width: 500px;
  margin: 0 auto 40px;
  line-height: 1.6;
  font-weight: 300;
}

/* 搜索 */
.search-container {
  max-width: 600px;
  margin: 0 auto;
}

.search-wrapper {
  display: flex;
  gap: 12px;
  background: var(--morandi-card);
  padding: 6px;
  border: 1px solid var(--morandi-border);
  border-radius: 8px;
  transition: all 0.3s ease;
}

.search-wrapper:hover,
.search-wrapper:focus-within {
  border-color: var(--morandi-accent);
  box-shadow: 0 2px 8px var(--morandi-shadow);
}

.search-input {
  flex: 1;
  border: none !important;
  box-shadow: none !important;
  background: transparent !important;
  font-size: 15px;
  padding: 12px 16px !important;
  color: var(--morandi-text);
  font-family: 'Inter', sans-serif;
  font-weight: 300;
}

.search-input::placeholder {
  color: var(--morandi-text-light);
  font-weight: 300;
}

.search-icon {
  color: var(--morandi-accent);
  font-size: 16px;
}

.search-button {
  border-radius: 6px !important;
  background: var(--morandi-accent) !important;
  border: none !important;
  padding: 12px 32px !important;
  height: auto !important;
  font-size: 14px;
  font-weight: 400;
  transition: all 0.3s ease !important;
  font-family: 'Inter', sans-serif;
}

.search-button:hover {
  background: var(--morandi-accent-hover) !important;
  transform: none;
  box-shadow: none;
}

/* 加载 */
.loading-container {
  text-align: center;
  padding: 60px 20px;
}

.loading-text {
  margin-top: 20px;
  color: var(--morandi-text-light);
  font-size: 14px;
  font-weight: 300;
}

/* 章节标题 */
.section-title {
  font-size: 24px;
  font-weight: 400;
  color: var(--morandi-text);
  margin-bottom: 32px;
  text-align: center;
  letter-spacing: -0.01em;
}

.section-title::before,
.section-title::after {
  display: none;
}

/* 搜索结果 */
.results-section {
  margin-bottom: 60px;
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 20px;
  margin-top: 32px;
}

.book-card {
  background: var(--morandi-card);
  border: 1px solid var(--morandi-border);
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
}

.book-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px var(--morandi-shadow);
  border-color: var(--morandi-accent);
}

.book-cover {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: var(--morandi-bg);
}

.book-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.book-card:hover .book-cover img {
  transform: scale(1.05);
}

.book-overlay {
  display: none;
}

.book-info {
  padding: 16px;
  background: var(--morandi-card);
}

.book-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--morandi-text);
  margin-bottom: 6px;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author {
  font-size: 12px;
  color: var(--morandi-text-light);
  margin-bottom: 4px;
  font-weight: 300;
}

.book-meta {
  font-size: 11px;
  color: var(--morandi-text-light);
  font-weight: 300;
}

/* 书籍详情 */
.book-detail-section {
  background: var(--morandi-card);
  border: 1px solid var(--morandi-border);
  border-radius: 8px;
  padding: 40px;
}

.book-detail-section::before {
  display: none;
}

.book-detail-header {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 32px;
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid var(--morandi-border);
}

.detail-cover {
  border: 1px solid var(--morandi-border);
  border-radius: 4px;
  overflow: hidden;
}

.detail-cover img {
  width: 100%;
  height: auto;
  display: block;
}

.detail-title {
  font-size: 28px;
  font-weight: 500;
  color: var(--morandi-text);
  margin-bottom: 12px;
  line-height: 1.3;
  letter-spacing: -0.01em;
}

.detail-author {
  font-size: 15px;
  color: var(--morandi-accent);
  margin-bottom: 8px;
  font-weight: 400;
}

.detail-author::before {
  display: none;
}

.detail-publisher {
  font-size: 13px;
  color: var(--morandi-text-light);
  margin-bottom: 16px;
  font-weight: 300;
}

.detail-summary {
  font-size: 14px;
  line-height: 1.7;
  color: var(--morandi-text-light);
  padding: 16px;
  background: var(--morandi-bg);
  border-left: 2px solid var(--morandi-accent);
  border-radius: 4px;
  font-weight: 300;
  text-indent: 0;
}

/* 摘抄 */
.quotes-section {
  margin-top: 32px;
}

.quotes-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--morandi-border);
  flex-wrap: wrap;
  gap: 12px;
}

.quotes-title {
  font-size: 20px;
  font-weight: 500;
  color: var(--morandi-text);
  letter-spacing: -0.01em;
  padding-left: 0;
}

.quotes-title::before {
  display: none;
}

.quotes-controls {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.select-all-checkbox {
  font-family: 'Inter', sans-serif;
  font-weight: 300;
}

.copy-button {
  background: var(--morandi-accent) !important;
  border: none !important;
  border-radius: 6px !important;
  padding: 10px 24px !important;
  height: auto !important;
  font-weight: 400;
  transition: all 0.3s ease !important;
  font-family: 'Inter', sans-serif;
  box-shadow: none;
}

.copy-button:hover:not(:disabled) {
  background: var(--morandi-accent-hover) !important;
  transform: none;
  box-shadow: none;
}

.copy-button:disabled {
  background: var(--morandi-border) !important;
  opacity: 0.5;
}

/* 摘抄列表 */
.quotes-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.quote-item {
  display: flex;
  gap: 16px;
  padding: 20px;
  background: var(--morandi-hover-bg);
  border: 1px solid transparent;
  border-radius: 6px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.quote-item::before {
  display: none;
}

.quote-item:hover {
  background: var(--morandi-card);
  border-color: var(--morandi-border);
  transform: none;
}

.quote-item.selected {
  background: var(--morandi-card);
  border-color: var(--morandi-accent);
  box-shadow: 0 2px 8px var(--morandi-shadow);
}

.quote-checkbox {
  padding-top: 2px;
}

.quote-content {
  flex: 1;
}

.quote-text {
  font-size: 15px;
  line-height: 1.7;
  color: var(--morandi-text);
  margin-bottom: 8px;
  font-weight: 300;
  text-indent: 0;
}

.quote-likes {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--morandi-accent);
  font-weight: 400;
}

.no-quotes {
  text-align: center;
  padding: 40px 20px;
  color: var(--morandi-text-light);
  font-size: 14px;
  font-weight: 300;
}

/* 使用说明 */
.instructions-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
  margin-top: 60px;
}

.instruction-card {
  background: var(--morandi-card);
  padding: 32px 24px;
  border: 1px solid var(--morandi-border);
  border-radius: 8px;
  transition: all 0.3s ease;
  text-align: center;
}

.instruction-card::before {
  display: none;
}

.instruction-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px var(--morandi-shadow);
  border-color: var(--morandi-accent);
}

.instruction-number {
  display: inline-block;
  width: 44px;
  height: 44px;
  line-height: 44px;
  border: 1px solid var(--morandi-border);
  border-radius: 50%;
  background: transparent;
  color: var(--morandi-accent);
  font-family: 'Inter', sans-serif;
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 16px;
  transition: all 0.3s ease;
}

.instruction-card:hover .instruction-number {
  background: var(--morandi-accent);
  color: white;
  border-color: var(--morandi-accent);
  transform: none;
}

.instruction-card h3 {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 500;
  color: var(--morandi-text);
  margin-bottom: 8px;
  letter-spacing: -0.01em;
}

.instruction-card p {
  font-size: 13px;
  line-height: 1.6;
  color: var(--morandi-text-light);
  font-weight: 300;
}

/* Ant Design 覆盖 */
.ant-checkbox-wrapper {
  font-size: 14px;
  color: var(--morandi-text);
  font-family: 'Inter', sans-serif;
  font-weight: 300;
}

.ant-checkbox-checked .ant-checkbox-inner {
  background-color: var(--morandi-accent);
  border-color: var(--morandi-accent);
}

.ant-checkbox-wrapper:hover .ant-checkbox-inner,
.ant-checkbox:hover .ant-checkbox-inner {
  border-color: var(--morandi-accent);
}

.ant-select-selector {
  border-radius: 6px !important;
  border-color: var(--morandi-border) !important;
  font-family: 'Inter', sans-serif !important;
  font-weight: 300;
}

.ant-select-focused .ant-select-selector {
  border-color: var(--morandi-accent) !important;
  box-shadow: none !important;
}

.ant-spin-dot-item {
  background-color: var(--morandi-accent);
}

.ant-message-notice-content {
  font-family: 'Inter', sans-serif;
  font-weight: 300;
}

/* 响应式 */
@media (max-width: 768px) {
  .book-quote-container {
    padding: 50px 20px 60px;
  }

  .hero-section {
    margin-bottom: 50px;
  }

  .search-wrapper {
    flex-direction: column;
  }

  .search-button {
    width: 100%;
  }

  .books-grid {
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 16px;
  }

  .book-detail-section {
    padding: 28px 20px;
  }

  .book-detail-header {
    grid-template-columns: 1fr;
    gap: 20px;
    text-align: center;
  }

  .detail-cover {
    max-width: 140px;
    margin: 0 auto;
  }

  .quotes-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .quotes-controls {
    width: 100%;
    flex-direction: column;
  }

  .template-select,
  .copy-button {
    width: 100%;
  }

  .instructions-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 480px) {
  .book-quote-container {
    padding: 40px 16px 50px;
  }

  .books-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .book-detail-section {
    padding: 24px 16px;
  }

  .quote-item {
    padding: 16px;
  }

  .quote-text {
    font-size: 14px;
  }
}
